# Supabase — from project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Google Maps JS API — enable Maps JS API + Places API in Cloud Console
VITE_GOOGLE_MAPS_KEY=your_google_maps_key_here

# GolfCourseAPI.com — used server-side only via Supabase Edge Function
# Set with: supabase secrets set GOLF_COURSE_API_KEY=your_key_here
# VITE_GOLF_COURSE_API_KEY is intentionally NOT exposed client-side
